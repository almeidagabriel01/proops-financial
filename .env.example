# ============================================
# Synkra AIOX Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (for multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic API — chat conversacional Premium (Epic 3)
# Get your key at: https://console.anthropic.com/
# - API Route (chat): process.env.ANTHROPIC_API_KEY
# - Model: claude-sonnet-4-6 (streaming, PT-BR, 20 msgs/dia por usuário Premium)
# - Opcional para categorização: claude-haiku-4-5-20251001 (batch)
# See: docs/ai-integration-roadmap.md
ANTHROPIC_API_KEY=

# Groq API — categorização de transações + transcrição de áudio (RECOMENDADO — gratuito)
# Get your key at: https://console.groq.com/keys
# - Edge Function (categorize-import): llama-3.1-8b-instant via supabase secrets set
# - API Route (audio): whisper-large-v3
# See: docs/ai-integration-roadmap.md
GROQ_API_KEY=

# Google Gemini API — alternativa para categorização (gratuito)
# Get your key at: https://aistudio.google.com/apikey
# - Edge Function (categorize-import): gemini-1.5-flash via supabase secrets set
# See: docs/ai-integration-roadmap.md
GOOGLE_AI_API_KEY=

# OpenAI API — alternativa para transcrição de áudio (US$0.006/min)
# Get yours at: https://platform.openai.com/api-keys
# - API Route (audio): whisper-1
# See: docs/ai-integration-roadmap.md
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend (Supabase)
# --------------------------------------------

# Supabase — get from project Settings > API
# NEXT_PUBLIC_ vars are safe for client (RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — server-only, NEVER expose to client (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking)
# Get from: sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Required for source map upload (widenClientFileUpload) — stack traces legíveis em produção
# Get from: sentry.io → Settings → Auth Tokens (escopos: project:releases, org:read)
SENTRY_AUTH_TOKEN=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# AIOX Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0

# --------------------------------------------
# Payments (Asaas)
# --------------------------------------------

# Asaas — server-only
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WEBHOOK_SECRET=your-webhook-secret

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
