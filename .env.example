# ============================================
# Finansim — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha com suas chaves reais.
# NUNCA commite .env.local com credenciais reais.
# ============================================

# --------------------------------------------
# Supabase (obrigatório)
# --------------------------------------------
# Obter em: Supabase Dashboard → Settings → API
# NEXT_PUBLIC_ é seguro para o cliente (RLS protege os dados)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key — server-only, NUNCA expor no cliente (bypassa RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------
# Google AI (obrigatório para IA)
# --------------------------------------------
# Obter em: https://aistudio.google.com — gratuito, sem cartão de crédito
# Free tier: 1.500 requests/dia para gemini-2.0-flash
# - Chat Basic: gemini-2.0-flash (free tier)
# - Chat Pro: gemini-2.5-flash (free tier limitado, pago ~$0,60/1M output)
# - Categorização: gemini-2.0-flash via Edge Function (free tier)
GOOGLE_AI_API_KEY=AIza...

# --------------------------------------------
# Pagamentos — Stripe (necessário para billing)
# --------------------------------------------
# Obter em: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Chave pública — segura para expor no cliente
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Obter em: dashboard.stripe.com/webhooks após criar o endpoint /api/webhook/stripe
# Gerar localmente: stripe listen --forward-to localhost:3000/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# IDs dos preços criados em dashboard.stripe.com/products
STRIPE_BASIC_MONTHLY_PRICE_ID=price_...
STRIPE_BASIC_ANNUAL_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# --------------------------------------------
# Groq (transcrição de áudio via Whisper)
# --------------------------------------------
# Obter em: console.groq.com — gratuito, sem cartão de crédito
GROQ_API_KEY=

# --------------------------------------------
# Sentry (opcional — monitoramento de erros)
# --------------------------------------------
# Obter em: sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...
SENTRY_DSN=https://...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
# Necessário para source maps em produção
# Escopos: project:releases, org:read
SENTRY_AUTH_TOKEN=

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------
# Testes E2E e Integração (staging Supabase)
# --------------------------------------------
# Projeto Supabase de staging dedicado para testes.
# Criar em: supabase.com → New Project
# Configurar também como GitHub Actions Secrets para CI.
TEST_SUPABASE_URL=https://xxx-staging.supabase.co
TEST_SUPABASE_ANON_KEY=your-staging-anon-key
TEST_SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Usuário E2E para testes locais (criado manualmente no staging)
# Em CI, criado automaticamente pelo workflow.
E2E_USER_EMAIL=e2e-local@test.finansim.app
E2E_USER_PASSWORD=Test@1234!
